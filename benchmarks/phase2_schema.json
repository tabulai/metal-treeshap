{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metal-treeshap.local/schemas/phase2.json",
  "title": "MetalTreeShap Phase-2 benchmark artifacts",
  "oneOf": [
    {"$ref": "#/$defs/workload"},
    {"$ref": "#/$defs/native_result"},
    {"$ref": "#/$defs/suite"},
    {"$ref": "#/$defs/cpu_xgboost"},
    {"$ref": "#/$defs/cpu_shap"},
    {"$ref": "#/$defs/power_summary"}
  ],
  "$defs": {
    "nonnegative_number": {"type": "number", "minimum": 0},
    "positive_integer": {"type": "integer", "minimum": 1},
    "timing_distribution": {
      "type": "object",
      "required": ["median", "p10", "p90", "samples"],
      "properties": {
        "median": {"$ref": "#/$defs/nonnegative_number"},
        "p10": {"$ref": "#/$defs/nonnegative_number"},
        "p90": {"$ref": "#/$defs/nonnegative_number"},
        "samples": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/nonnegative_number"}
        }
      },
      "additionalProperties": false
    },
    "workload": {
      "type": "object",
      "required": ["schema", "name", "paths", "matrix", "expected", "rows", "cols",
                   "num_groups", "intercepts", "sha256"],
      "properties": {
        "schema": {"const": "metal_treeshap.phase2.workload.v1"},
        "name": {"type": "string", "minLength": 1},
        "paths": {"type": "string", "minLength": 1},
        "matrix": {"type": "string", "minLength": 1},
        "expected": {"type": ["string", "null"]},
        "rows": {"$ref": "#/$defs/positive_integer"},
        "cols": {"$ref": "#/$defs/positive_integer"},
        "num_groups": {"$ref": "#/$defs/positive_integer"},
        "intercepts": {"type": "array", "minItems": 1, "items": {"type": "number"}},
        "sha256": {"type": "object", "additionalProperties": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "native_result": {
      "type": "object",
      "required": ["schema", "status", "workload", "configuration", "setup_s",
                   "timing_s", "throughput", "repeatability", "accuracy"],
      "properties": {
        "schema": {"const": "metal_treeshap.phase2.benchmark.v1"},
        "status": {"const": "ok"},
        "workload": {
          "type": "object",
          "required": ["rows", "cols", "groups", "raw_path_elements", "packed_bins"],
          "properties": {
            "rows": {"$ref": "#/$defs/positive_integer"},
            "cols": {"$ref": "#/$defs/positive_integer"},
            "groups": {"$ref": "#/$defs/positive_integer"},
            "raw_path_elements": {"type": "integer", "minimum": 0},
            "packed_bins": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": true
        },
        "configuration": {
          "type": "object",
          "required": ["rows_per_simdgroup", "threads_per_threadgroup", "accumulation",
                       "model_storage", "deterministic_scratch_mib", "warmups", "iterations"],
          "properties": {
            "rows_per_simdgroup": {"$ref": "#/$defs/positive_integer"},
            "threads_per_threadgroup": {"enum": [32, 64, 128, 256]},
            "accumulation": {"enum": ["atomic", "simdgroup", "deterministic"]},
            "model_storage": {"enum": ["shared", "private"]},
            "deterministic_scratch_mib": {"$ref": "#/$defs/positive_integer"},
            "atomic_tile_rows": {"type": "integer", "minimum": 0},
            "warmups": {"type": "integer", "minimum": 0},
            "iterations": {"$ref": "#/$defs/positive_integer"}
          },
          "additionalProperties": true
        },
        "setup_s": {"type": "object", "additionalProperties": {"$ref": "#/$defs/nonnegative_number"}},
        "timing_s": {
          "type": "object",
          "required": ["wall", "gpu", "x_zero_copy_samples", "deterministic_runtime"],
          "properties": {
            "wall": {"$ref": "#/$defs/timing_distribution"},
            "gpu": {"$ref": "#/$defs/timing_distribution"},
            "x_zero_copy_samples": {
              "type": "array",
              "items": {"enum": [0, 1]}
            },
            "deterministic_runtime": {
              "type": "object",
              "required": ["active_scratch_bytes_samples", "tile_rows_samples",
                           "tile_count_samples"]
            }
          },
          "additionalProperties": true
        },
        "throughput": {"type": "object"},
        "repeatability": {
          "type": "object",
          "description": "Exact elementwise max-pairwise spread across all measured runs.",
          "required": ["hashes", "unique_hashes", "max_pairwise_abs",
                       "max_pairwise_relative_symmetric", "relative_floor"],
          "properties": {
            "max_pairwise_abs": {"$ref": "#/$defs/nonnegative_number"},
            "max_pairwise_relative_symmetric": {"$ref": "#/$defs/nonnegative_number"}
          },
          "additionalProperties": true
        },
        "accuracy": {
          "description": "First-run and worst-over-all-runs deviation from expected output.",
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "required": ["first_run_max_abs", "first_run_max_relative",
                           "first_run_mean_abs", "first_run_max_row_group_sum_abs",
                           "worst_run_max_abs", "worst_run_max_relative",
                           "worst_run_mean_abs", "worst_run_max_row_group_sum_abs"]
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "cpu_xgboost": {
      "type": "object",
      "required": ["schema", "created_utc", "environment", "inputs", "design",
                   "setup_s", "results"],
      "properties": {
        "schema": {"const": "metal_treeshap.phase2.cpu_xgboost.v1"},
        "created_utc": {"type": "string"},
        "environment": {"type": "object"},
        "inputs": {"type": "object"},
        "design": {"type": "object"},
        "setup_s": {"type": "object"},
        "results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["rows", "dmatrix_setup_s", "timing_s",
                         "throughput_rows_per_s", "repeatability", "accuracy"],
            "properties": {
              "rows": {"$ref": "#/$defs/positive_integer"},
              "timing_s": {"$ref": "#/$defs/timing_distribution"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "cpu_shap": {
      "type": "object",
      "required": ["schema", "created_utc", "status", "environment", "inputs",
                   "design", "results"],
      "properties": {
        "schema": {"const": "metal_treeshap.phase2.cpu_shap.v1"},
        "created_utc": {"type": "string"},
        "status": {"enum": ["ok", "skipped"]},
        "environment": {"type": "object"},
        "inputs": {"type": "object"},
        "design": {"type": "object"},
        "results": {"type": "array"},
        "skip_reason": {"type": "string"},
        "backend_provenance": {"type": "object"},
        "setup_s": {"type": "object"}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "ok"}}},
          "then": {"required": ["backend_provenance", "setup_s"]}
        },
        {
          "if": {"properties": {"status": {"const": "skipped"}}},
          "then": {"required": ["skip_reason"]}
        }
      ],
      "additionalProperties": false
    },
    "power_summary": {
      "type": "object",
      "required": ["schema", "suite", "powermetrics", "jobs"],
      "properties": {
        "schema": {"const": "metal_treeshap.phase2.power_summary.v1"},
        "suite": {"type": "string"},
        "powermetrics": {"type": "string"},
        "jobs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["status", "overlapping_samples", "job_duration_s", "provenance"],
            "properties": {
              "status": {"enum": ["ok", "unavailable"]},
              "overlapping_samples": {"type": "integer", "minimum": 0},
              "job_duration_s": {"$ref": "#/$defs/nonnegative_number"},
              "gpu_mean_mw": {"$ref": "#/$defs/nonnegative_number"},
              "gpu_estimated_energy_j": {"$ref": "#/$defs/nonnegative_number"},
              "cpu_mean_mw": {"$ref": "#/$defs/nonnegative_number"},
              "cpu_estimated_energy_j": {"$ref": "#/$defs/nonnegative_number"},
              "provenance": {"type": "object"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "suite": {
      "type": "object",
      "required": ["schema", "created_utc", "environment", "design", "workloads", "results"],
      "properties": {
        "schema": {"const": "metal_treeshap.phase2.suite.v1"},
        "created_utc": {"type": "string"},
        "environment": {"type": "object"},
        "design": {"type": "object"},
        "workloads": {"type": "array", "items": {"$ref": "#/$defs/workload"}},
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sequence", "outer_round", "workload_name", "command", "native"],
            "properties": {
              "native": {"$ref": "#/$defs/native_result"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    }
  }
}
